{
  "name": "havenfall-v1",
  "version": "1.7.0",
  "private": true,
  "description": "HavenFall Desktop Edition — survival/colony sim 2D empacotado com Tauri.",
  "main": "electron-main.cjs",
  "scripts": {
    "start": "npm run tauri:dev",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:icon": "tauri icon src-tauri/icons/icon.png",
    "dev:web": "node server.js",
    "build:web": "node scripts/build-web.mjs",
    "desktop": "electron .",
    "electron": "electron .",
    "desktop:dev": "electron . --devtools",
    "desktop:diagnose": "node scripts/desktop-doctor.cjs",
    "web": "node server.js",
    "assets:process": "node scripts/process-assets.mjs",
    "icons:prepare": "node scripts/prepare-icons.cjs",
    "test:logic": "node --test tests/*.test.mjs",
    "test:smoke": "node tests/smoke.mjs",
    "test:systems": "node tests/smoke-systems.mjs",
    "test:smoke:phaser": "node tests/smoke-phaser.mjs",
    "check:types": "tsc --noEmit",
    "dist:win": "npm run icons:prepare && electron-builder --win nsis portable",
    "dist:win:setup": "npm run icons:prepare && electron-builder --win nsis",
    "dist:win:portable": "npm run icons:prepare && electron-builder --win portable",
    "pack:win": "npm run icons:prepare && electron-builder --win --dir"
  },
  "keywords": [
    "2d",
    "survival",
    "colony",
    "canvas",
    "game",
    "desktop",
    "tauri",
    "rust",
    "seed"
  ],
  "author": "Enzo + ChatGPT",
  "license": "UNLICENSED",
  "devDependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/cli": "^2.11.4",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "gifuct-js": "^2.1.2",
    "playwright": "^1.61.1",
    "pngjs": "^7.0.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "phaser": "^3.90.0"
  },
  "build": {
    "appId": "br.com.tpolltech.havenfall",
    "productName": "HavenFall Desktop",
    "artifactName": "HavenFall-Desktop-${version}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "index.html",
      "logo.png",
      "menu.png",
      "assets/**/*",
      "src/**/*",
      "node_modules/phaser/dist/phaser.min.js",
      "electron-main.cjs",
      "electron-preload.cjs",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron-main.cjs"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "HavenFall Desktop",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "deleteAppDataOnUninstall": false
    }
  }
}
