{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HavenFall",
  "version": "1.7.0",
  "identifier": "br.com.tpolltech.havenfall",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build:web",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "HavenFall",
        "width": 1280,
        "height": 800,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "visible": false,
        "decorations": true,
        "transparent": false,
        "backgroundColor": "#080b10"
      }
    ],
    "security": {
      "csp": "default-src 'self' data: blob:; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' http: https: ws: wss:; font-src 'self' data:;"
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png",
      "icons/icon.icns"
    ],
    "windows": {
      "nsis": {}
    },
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": "TPollTech",
      "signingIdentity": null
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libayatana-appindicator3-1", "librsvg2-2"]
      },
      "appimage": {},
      "rpm": {}
    }
  },
  "plugins": {
    "fs": {
      "scope": {
        "allow": [
          "$APPDATA/HavenFall/**",
          "$APPDATA/HavenFall/saves/**",
          "$APPDATA/HavenFall/backups/**"
        ]
      }
    },
    "dialog": {
      "all": true,
      "open": true,
      "save": true
    },
    "shell": {
      "all": false,
      "open": true
    }
  }
}