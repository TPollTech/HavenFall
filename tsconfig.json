{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "strict": false,
    "skipLibCheck": true,
    "types": []
  },
  "include": [
    "src/**/*.js",
    "tests/**/*.mjs",
    "src/types/**/*.d.ts"
  ],
  "exclude": [
    "src/legacy/**",
    "node_modules/**"
  ]
}
